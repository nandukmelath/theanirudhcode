# WhatsApp AI agent — env vars. Copy the ones you need into Cloud Run (or a local .env).

# ── AI provider ───────────────────────────────────────────────────────────────
AI_PROVIDER=anthropic            # "anthropic" (default) or "groq"

# Claude (AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
AI_AGENT_MODEL=claude-haiku-4-5  # optional; claude-opus-4-8 for max quality

# Groq (AI_PROVIDER=groq) — for testing
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile   # optional

# ── WhatsApp Business Cloud API (Meta) ─────────────────────────────────────────
WHATSAPP_PHONE_ID=               # Meta → WhatsApp → API Setup → Phone number ID
WHATSAPP_TOKEN=                  # permanent System User token
WHATSAPP_VERIFY_TOKEN=           # any random string; paste the same into Meta
WHATSAPP_APP_SECRET=             # Meta → App → Settings → Basic → App Secret
WHATSAPP_ADMIN_NUMBER=           # doctor's WhatsApp for escalation pings, e.g. 9198XXXXXXXX

# For LOCAL testing the webhook needs NODE_ENV unset (or != production) so it accepts
# unsigned requests while WHATSAPP_APP_SECRET isn't wired. Set it in prod.
