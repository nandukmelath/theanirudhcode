generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ═══════════════════════════════════════
//  ENUMS
// ═══════════════════════════════════════

enum Role {
  patient
  admin
}

enum ConsultationStatus {
  new
  read
  contacted
  completed
}

enum AppointmentStatus {
  confirmed
  cancelled
  completed
  rescheduled
}

// ═══════════════════════════════════════
//  MODELS
// ═══════════════════════════════════════

model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  passwordHash String        @map("password_hash")
  phone        String?
  role         Role          @default(patient)
  isActive     Boolean       @default(true) @map("is_active")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  createdAt    DateTime      @default(now()) @map("created_at")
  appointments   Appointment[]
  passwordResets PasswordReset[]

  @@map("users")
}

model Subscriber {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  source       String   @default("free-guide")
  subscribedAt DateTime @default(now()) @map("subscribed_at")
  isActive     Boolean  @default(true) @map("is_active")

  @@map("subscribers")
}

model Consultation {
  id            Int                @id @default(autoincrement())
  name          String
  email         String
  phone         String?
  preferredDate String?            @map("preferred_date")
  message       String?
  status        ConsultationStatus @default(new)
  adminReply    String?            @map("admin_reply")
  repliedAt     DateTime?          @map("replied_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  @@map("consultations")
}

model Appointment {
  id                 Int               @id @default(autoincrement())
  userId             Int               @map("user_id")
  date               String
  timeStart          String            @map("time_start")
  timeEnd            String            @map("time_end")
  status             AppointmentStatus @default(confirmed)
  consultationType   String            @default("deepdive") @map("consultation_type")
  consultationPrice  Int               @default(5000) @map("consultation_price")
  healthConcerns     String?           @map("health_concerns")
  medicalHistory     String?           @map("medical_history")
  goals              String?
  googleEventId      String?           @map("google_event_id")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  user               User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([date])
  @@index([status])
  @@map("appointments")
}

model Product {
  id          Int            @id @default(autoincrement())
  title       String
  description String
  price       Int
  category    String
  badge       String?
  features    String?
  available   Boolean        @default(true)
  createdAt   DateTime       @default(now()) @map("created_at")
  orders      ProductOrder[]

  @@map("products")
}

model ProductOrder {
  id        Int      @id @default(autoincrement())
  productId Int      @map("product_id")
  name      String
  email     String
  phone     String?
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at")
  product   Product  @relation(fields: [productId], references: [id])

  @@map("product_orders")
}

model Cohort {
  id              Int                @id @default(autoincrement())
  name            String
  tagline         String
  description     String
  startDate       String             @map("start_date")
  durationWeeks   Int                @map("duration_weeks")
  price           Int
  maxParticipants Int                @map("max_participants")
  spotsLeft       Int                @map("spots_left")
  isActive        Boolean            @default(true) @map("is_active")
  createdAt       DateTime           @default(now()) @map("created_at")
  enrollments     CohortEnrollment[]

  @@map("cohorts")
}

model CohortEnrollment {
  id        Int      @id @default(autoincrement())
  cohortId  Int      @map("cohort_id")
  name      String
  email     String
  phone     String?
  message   String?
  status    String   @default("waitlist")
  createdAt DateTime @default(now()) @map("created_at")
  cohort    Cohort   @relation(fields: [cohortId], references: [id])

  @@map("cohort_enrollments")
}

model Post {
  id         Int      @id @default(autoincrement())
  title      String
  slug       String   @unique
  category   String
  tags       String?
  excerpt    String
  content    String
  canvasType String   @default("gut") @map("canvas_type")
  published  Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("posts")
}

model Setting {
  key   String @id
  value String

  @@map("settings")
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("password_resets")
}

model GoogleToken {
  id           Int     @id @default(1)
  accessToken  String? @map("access_token")
  refreshToken String? @map("refresh_token")
  expiry       String?
  calendarId   String? @map("calendar_id")

  @@map("google_tokens")
}
