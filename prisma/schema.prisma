generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ═══════════════════════════════════════
//  ENUMS
// ═══════════════════════════════════════

enum Role {
  patient
  admin
}

enum ConsultationStatus {
  new
  read
  contacted
  completed
}

enum AppointmentStatus {
  confirmed
  cancelled
  completed
  rescheduled
}

// ═══════════════════════════════════════
//  MODELS
// ═══════════════════════════════════════

model User {
  id                           Int           @id @default(autoincrement())
  name                         String
  email                        String        @unique
  passwordHash                 String        @map("password_hash")
  phone                        String?
  role                         Role          @default(patient)
  isActive                     Boolean       @default(true) @map("is_active")
  emailVerified                Boolean       @default(true) @map("email_verified")
  emailVerificationTokenHash   String?       @map("email_verification_token_hash")
  emailVerificationExpiresAt   DateTime?     @map("email_verification_expires_at")
  failedLoginAttempts          Int           @default(0) @map("failed_login_attempts")
  lockedUntil                  DateTime?     @map("locked_until")
  passwordChangedAt            DateTime?     @map("password_changed_at")
  // ── Tier 1: Quick profile (collected at signup) ────────────────────────────
  dateOfBirth                  DateTime?     @map("date_of_birth") @db.Date
  sex                          String?       // "male" | "female" | "other" | "prefer_not_to_say"
  country                      String?       // ISO 2-letter code
  city                         String?
  referralSource               String?       @map("referral_source") // instagram, friend, google, youtube, podcast, other
  // ── Tier 2: Health intake (collected before first booking) ─────────────────
  heightCm                     Int?          @map("height_cm")
  weightKg                     Float?        @map("weight_kg")
  primaryGoal                  String?       @map("primary_goal") // weight | hormonal | gut | sleep | energy | longevity | other
  conditions                   String?       // CSV: "diabetes,pcos,thyroid"
  medications                  String?       @db.Text
  dietType                     String?       @map("diet_type") // vegetarian | vegan | jain | omnivore | eggetarian
  sleepHours                   Int?          @map("sleep_hours")
  exerciseLevel                String?       @map("exercise_level") // sedentary | light | moderate | active | athlete
  occupation                   String?
  // ── Tier 3: Marketing preferences ──────────────────────────────────────────
  marketingOptIn               Boolean       @default(false) @map("marketing_opt_in")
  preferredChannel             String?       @map("preferred_channel") // email | whatsapp | sms
  bestContactTime              String?       @map("best_contact_time") // morning | afternoon | evening
  language                     String?       @default("en") // en | hi | te | ta
  // ── Consent ────────────────────────────────────────────────────────────────
  privacyConsentAt             DateTime?     @map("privacy_consent_at")
  intakeCompletedAt            DateTime?     @map("intake_completed_at")
  createdAt                    DateTime      @default(now()) @map("created_at")
  appointments   Appointment[]
  passwordResets PasswordReset[]

  @@map("users")
}

model Subscriber {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  source       String   @default("free-guide")
  subscribedAt DateTime @default(now()) @map("subscribed_at")
  isActive     Boolean  @default(true) @map("is_active")

  @@map("subscribers")
}

model Consultation {
  id            Int                @id @default(autoincrement())
  name          String
  email         String
  phone         String?
  preferredDate String?            @map("preferred_date")
  message       String?
  status        ConsultationStatus @default(new)
  adminReply    String?            @map("admin_reply")
  repliedAt     DateTime?          @map("replied_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  @@map("consultations")
}

model Appointment {
  id                 Int               @id @default(autoincrement())
  userId             Int               @map("user_id")
  date               String
  timeStart          String            @map("time_start")
  timeEnd            String            @map("time_end")
  status             AppointmentStatus @default(confirmed)
  consultationType   String            @default("deepdive") @map("consultation_type")
  consultationPrice  Int               @default(5000) @map("consultation_price")
  healthConcerns     String?           @map("health_concerns")
  medicalHistory     String?           @map("medical_history")
  goals              String?
  googleEventId      String?           @map("google_event_id")
  // Payment
  paymentStatus      String            @default("pending") @map("payment_status")
  paymentId          String?           @map("payment_id")
  paymentOrderId     String?           @map("payment_order_id")
  paymentGateway     String?           @map("payment_gateway")
  currency           String            @default("INR")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  user               User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([date])
  @@index([status])
  @@index([paymentOrderId])
  @@map("appointments")
}

model Product {
  id          Int            @id @default(autoincrement())
  title       String
  description String
  price       Int
  category    String
  badge       String?
  features    String?
  available   Boolean        @default(true)
  createdAt   DateTime       @default(now()) @map("created_at")
  orders      ProductOrder[]

  @@map("products")
}

model ProductOrder {
  id             Int      @id @default(autoincrement())
  productId      Int      @map("product_id")
  name           String
  email          String
  phone          String?
  status         String   @default("pending")
  paymentStatus  String   @default("pending") @map("payment_status")
  paymentId      String?  @map("payment_id")
  paymentOrderId String?  @map("payment_order_id")
  paymentGateway String?  @map("payment_gateway")
  currency       String   @default("INR")
  amountPaid     Int?     @map("amount_paid")
  createdAt      DateTime @default(now()) @map("created_at")
  product        Product  @relation(fields: [productId], references: [id])

  @@index([paymentOrderId])
  @@map("product_orders")
}

model Cohort {
  id              Int                @id @default(autoincrement())
  name            String
  tagline         String
  description     String
  startDate       String             @map("start_date")
  durationWeeks   Int                @map("duration_weeks")
  price           Int
  maxParticipants Int                @map("max_participants")
  spotsLeft       Int                @map("spots_left")
  isActive        Boolean            @default(true) @map("is_active")
  createdAt       DateTime           @default(now()) @map("created_at")
  enrollments     CohortEnrollment[]

  @@map("cohorts")
}

model CohortEnrollment {
  id             Int      @id @default(autoincrement())
  cohortId       Int      @map("cohort_id")
  name           String
  email          String
  phone          String?
  message        String?
  status         String   @default("waitlist")
  paymentStatus  String   @default("pending") @map("payment_status")
  paymentId      String?  @map("payment_id")
  paymentOrderId String?  @map("payment_order_id")
  paymentGateway String?  @map("payment_gateway")
  currency       String   @default("INR")
  amountPaid     Int?     @map("amount_paid")
  createdAt      DateTime @default(now()) @map("created_at")
  cohort         Cohort   @relation(fields: [cohortId], references: [id])

  @@index([paymentOrderId])
  @@map("cohort_enrollments")
}

model Post {
  id         Int      @id @default(autoincrement())
  title      String
  slug       String   @unique
  category   String
  tags       String?
  excerpt    String
  content    String
  canvasType String   @default("gut") @map("canvas_type")
  published  Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("posts")
}

model Setting {
  key   String @id
  value String

  @@map("settings")
}

model EmailOtp {
  id        Int      @id @default(autoincrement())
  email     String
  codeHash  String   @map("code_hash")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  purpose   String   @default("login") // "login" | "register" | "verify"
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([expiresAt])
  @@map("email_otps")
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("password_resets")
}

model GoogleToken {
  id           Int     @id @default(1)
  accessToken  String? @map("access_token")
  refreshToken String? @map("refresh_token")
  expiry       String?
  calendarId   String? @map("calendar_id")

  @@map("google_tokens")
}

model BlockedSlot {
  id          Int      @id @default(autoincrement())
  date        String
  timeStart   String   @map("time_start")
  timeEnd     String   @map("time_end")
  reason      String?
  gcalEventId String?  @map("gcal_event_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([date, timeStart])
  @@index([date])
  @@map("blocked_slots")
}

// ═══════════════════════════════════════
//  AGENT OPS (24/7 autonomous agents)
// ═══════════════════════════════════════

model AgentRun {
  id          BigInt           @id @default(autoincrement())
  agentName   String           @map("agent_name")
  parentRunId BigInt?          @map("parent_run_id")
  status      String           @default("running")
  trigger     String?
  input       Json?
  output      Json?
  error       String?
  model       String?
  tokensIn    Int?             @map("tokens_in")
  tokensOut   Int?             @map("tokens_out")
  costUsd     Decimal?         @map("cost_usd") @db.Decimal(10, 6)
  startedAt   DateTime         @default(now()) @map("started_at")
  finishedAt  DateTime?        @map("finished_at")
  parent      AgentRun?        @relation("AgentRunChildren", fields: [parentRunId], references: [id], onDelete: SetNull)
  children    AgentRun[]       @relation("AgentRunChildren")
  decisions   AgentDecision[]
  approvals   ApprovalRequest[]
  digestItems DigestItem[]

  @@index([agentName])
  @@index([status])
  @@index([startedAt])
  @@map("agent_runs")
}

model AgentDecision {
  id               BigInt            @id @default(autoincrement())
  runId            BigInt            @map("run_id")
  actionType       String            @map("action_type")
  targetTable      String?           @map("target_table")
  targetId         String?           @map("target_id")
  payload          Json?
  requiresApproval Boolean           @default(false) @map("requires_approval")
  executed         Boolean           @default(false)
  executedAt       DateTime?         @map("executed_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  run              AgentRun          @relation(fields: [runId], references: [id], onDelete: Cascade)
  approvals        ApprovalRequest[]

  @@index([runId])
  @@index([executed])
  @@map("agent_decisions")
}

model ApprovalRequest {
  id              BigInt         @id @default(autoincrement())
  decisionId      BigInt?        @map("decision_id")
  agentRunId      BigInt?        @map("agent_run_id")
  actionType      String         @map("action_type")
  summary         String
  draftContent    String?        @map("draft_content")
  channel         String         @default("whatsapp")
  status          String         @default("pending")
  requestedAt     DateTime       @default(now()) @map("requested_at")
  expiresAt       DateTime?      @map("expires_at")
  decidedAt       DateTime?      @map("decided_at")
  decidedBy       String?        @map("decided_by")
  decisionNote    String?        @map("decision_note")
  callbackPayload Json?          @map("callback_payload")
  decision        AgentDecision? @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  run             AgentRun?      @relation(fields: [agentRunId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([expiresAt])
  @@map("approval_queue")
}

model DigestItem {
  id          BigInt    @id @default(autoincrement())
  digestDate  DateTime  @map("digest_date") @db.Date
  category    String
  severity    String    @default("info")
  title       String
  detail      String?
  agentRunId  BigInt?   @map("agent_run_id")
  delivered   Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  run         AgentRun? @relation(fields: [agentRunId], references: [id], onDelete: SetNull)

  @@index([digestDate])
  @@index([category])
  @@map("digest_items")
}
